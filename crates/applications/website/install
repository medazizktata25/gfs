#!/usr/bin/env bash
set -euo pipefail
APP=gfs

MUTED='\033[0;2m'
RED='\033[0;31m'
ORANGE='\033[38;5;214m'
NC='\033[0m' # No Color

usage() {
    cat <<EOF
GFS Installer

Usage: install.sh [options]

Options:
    -h, --help              Display this help message
    -v, --version <version> Install a specific version (e.g., 0.1.3)
    -b, --binary <path>     Install from a local binary instead of downloading
        --no-modify-path    Don't modify shell config files (.zshrc, .bashrc, etc.)
        --skip-docker-check Skip Docker installation check and prompt
        --skip-ai-tools     Skip AI coding tools detection and injection (Cursor, Claude, OpenCode)

Examples:
    curl -fsSL https://gfs.guepard.run/install | bash
    curl -fsSL https://gfs.guepard.run/install | bash -s -- --version 0.1.3
    ./install --binary /path/to/gfs
    ./install --skip-docker-check   # Skip Docker check (e.g. CI)
    ./install --skip-ai-tools      # Skip AI tools injection
EOF
}

requested_version=${VERSION:-}
no_modify_path=false
binary_path=""
skip_docker_check=false
skip_ai_tools=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            if [[ -n "${2:-}" ]]; then
                requested_version="$2"
                shift 2
            else
                echo -e "${RED}Error: --version requires a version argument${NC}"
                exit 1
            fi
            ;;
        -b|--binary)
            if [[ -n "${2:-}" ]]; then
                binary_path="$2"
                shift 2
            else
                echo -e "${RED}Error: --binary requires a path argument${NC}"
                exit 1
            fi
            ;;
        --no-modify-path)
            no_modify_path=true
            shift
            ;;
        --skip-docker-check)
            skip_docker_check=true
            shift
            ;;
        --skip-ai-tools)
            skip_ai_tools=true
            shift
            ;;
        *)
            echo -e "${ORANGE}Warning: Unknown option '$1'${NC}" >&2
            shift
            ;;
    esac
done

INSTALL_DIR=$HOME/.gfs/bin
mkdir -p "$INSTALL_DIR"

# Detect platform for Docker check (needed regardless of install mode)
detect_platform_for_docker() {
    raw_os=$(uname -s)
    case "$raw_os" in
        Darwin*) echo "macos" ;;
        Linux*) echo "linux" ;;
        MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
        *) echo "unknown" ;;
    esac
}

check_and_install_docker() {
    if [[ "$skip_docker_check" == "true" ]]; then
        return 0
    fi

    if command -v docker >/dev/null 2>&1; then
        docker_version=$(docker --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
        if [[ -n "$docker_version" ]]; then
            echo -e "✅ ${MUTED}Docker detected (version $docker_version).${NC}"
        else
            echo -e "✅ ${MUTED}Docker detected.${NC}"
        fi
        return 0
    fi

    if command -v podman >/dev/null 2>&1; then
        podman_version=$(podman --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
        if [[ -n "$podman_version" ]]; then
            echo -e "✅ ${MUTED}Podman detected (version $podman_version).${NC}"
        else
            echo -e "✅ ${MUTED}Podman detected.${NC}"
        fi
        return 0
    fi

    local platform
    platform=$(detect_platform_for_docker)

    echo -e ""
    echo -e "⚠️  ${ORANGE}No container runtime detected. GFS requires Docker or Podman to manage database containers.${NC}"
    echo -e ""
    case "$platform" in
        macos)
            echo -e "On macOS, you can install Docker Desktop with: ${MUTED}brew install --cask docker${NC}"
            echo -e "Or download from: https://www.docker.com/products/docker-desktop/"
            ;;
        linux)
            echo -e "On Linux, you can install Docker Engine (docker-ce) using your distribution's package manager."
            echo -e "Or run: ${MUTED}curl -fsSL https://get.docker.com | sudo sh${NC}"
            ;;
        windows)
            echo -e "On Windows, install Docker Desktop from: https://www.docker.com/products/docker-desktop/"
            ;;
        *)
            echo -e "Please install Docker from: https://docs.docker.com/get-docker/"
            ;;
    esac
    echo -e ""
    if [ -t 0 ]; then
        printf "Would you like to install Docker now? [y/N] "
        read -r response
        case "$response" in
            [yY][eE][sS]|[yY])
                install_docker "$platform"
                ;;
            *)
                echo -e "${MUTED}Skipping Docker installation. You can install it later and run GFS.${NC}"
                ;;
        esac
    else
        echo -e "${MUTED}Run the installer interactively to get the option to install Docker.${NC}"
    fi
}

install_docker() {
    local platform=$1
    case "$platform" in
        macos)
            if command -v brew >/dev/null 2>&1; then
                echo -e "${MUTED}Installing Docker Desktop via Homebrew...${NC}"
                brew install --cask docker
                echo -e "${NC}Docker Desktop installed. You may need to open Docker from Applications to start the daemon.${NC}"
            else
                echo -e "${RED}Homebrew is required to install Docker on macOS.${NC}"
                echo -e "Install Homebrew: https://brew.sh"
                echo -e "Or download Docker Desktop: https://www.docker.com/products/docker-desktop/"
            fi
            ;;
        linux)
            if command -v curl >/dev/null 2>&1; then
                echo -e "${MUTED}Installing Docker Engine via get.docker.com...${NC}"
                if curl -fsSL https://get.docker.com | sudo sh; then
                    echo -e "${NC}Docker installed. You may need to add your user to the 'docker' group: ${MUTED}sudo usermod -aG docker \$USER${NC}"
                else
                    echo -e "${RED}Docker installation failed. Try manually: https://docs.docker.com/engine/install/${NC}"
                fi
            else
                echo -e "${RED}curl is required to install Docker. Install curl first.${NC}"
            fi
            ;;
        windows)
            echo -e "${ORANGE}On Windows, please install Docker Desktop manually:${NC}"
            echo -e "https://www.docker.com/products/docker-desktop/"
            ;;
        *)
            echo -e "${ORANGE}Please install Docker manually: https://docs.docker.com/get-docker/${NC}"
            ;;
    esac
}

check_and_install_docker

# Detect AI coding tools and print summary (like Docker)
detect_ai_coding_tools() {
    local detected=()
    # Cursor
    if [[ -d "$HOME/.cursor" ]] || [[ -f "$HOME/.cursor/mcp.json" ]]; then
        detected+=("Cursor")
    fi
    # Claude (platform-specific)
    if [[ "$(uname -s)" == "Darwin"* ]] && [[ -d "$HOME/Library/Application Support/Claude" ]]; then
        detected+=("Claude")
    elif [[ -d "${XDG_CONFIG_HOME:-$HOME/.config}/Claude" ]]; then
        detected+=("Claude")
    elif [[ -n "${APPDATA:-}" ]] && [[ -d "$APPDATA/Claude" ]]; then
        detected+=("Claude")
    fi
    # OpenCode
    if [[ -d "${XDG_CONFIG_HOME:-$HOME/.config}/opencode" ]] || command -v opencode >/dev/null 2>&1; then
        detected+=("OpenCode")
    fi
    printf '%s\n' "${detected[@]}"
}

print_ai_tools_detection_summary() {
    if [[ "$skip_ai_tools" == "true" ]]; then
        return 0
    fi
    local detected
    detected=($(detect_ai_coding_tools))
    if [[ ${#detected[@]} -gt 0 ]]; then
        for tool in "${detected[@]}"; do
            echo -e "✅ ${MUTED}${tool} detected.${NC}"
        done
    else
        echo -e "${MUTED}No AI coding tools detected (Cursor, Claude, OpenCode).${NC}"
    fi
}

print_ai_tools_detection_summary

# If --binary is provided, skip all download/detection logic
if [ -n "$binary_path" ]; then
    if [ ! -f "$binary_path" ]; then
        echo -e "${RED}Error: Binary not found at ${binary_path}${NC}"
        exit 1
    fi
    specific_version="local"
else
    raw_os=$(uname -s)
    os=$(echo "$raw_os" | tr '[:upper:]' '[:lower:]')
    case "$raw_os" in
      Darwin*) os="macos" ;;
      Linux*) os="linux" ;;
      MINGW*|MSYS*|CYGWIN*) os="windows" ;;
    esac

    arch=$(uname -m)
    # Normalize architecture names to match GitHub release assets
    if [[ "$arch" == "arm64" ]]; then
      arch="aarch64"
    fi
    # Keep x86_64 as is - it matches the release naming

    if [ "$os" = "macos" ] && [ "$arch" = "x86_64" ]; then
      rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
      if [ "$rosetta_flag" = "1" ]; then
        arch="aarch64"
      fi
    fi

    combo="$os-$arch"
    case "$combo" in
      linux-x86_64|linux-aarch64|macos-x86_64|macos-aarch64|windows-x86_64)
        ;;
      *)
        echo -e "${RED}Unsupported OS/Arch: $os/$arch${NC}"
        exit 1
        ;;
    esac

    # All platforms use .tar.gz in the current release
    archive_ext=".tar.gz"

    # Build the filename based on the GitHub release naming convention
    filename="$APP-$os-$arch$archive_ext"


    if ! command -v curl >/dev/null 2>&1; then
        echo -e "${RED}Error: 'curl' is required but not installed.${NC}"
        exit 1
    fi

    if ! command -v tar >/dev/null 2>&1; then
        echo -e "${RED}Error: 'tar' is required but not installed.${NC}"
        exit 1
    fi

    if [ -z "$requested_version" ]; then
        url="https://github.com/Guepard-Corp/gfs/releases/latest/download/$filename"
        specific_version=$(curl -s https://api.github.com/repos/Guepard-Corp/gfs/releases/latest 2>/dev/null | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')

        if [[ -z "$specific_version" ]]; then
            echo -e "${RED}Failed to fetch version information${NC}"
            exit 1
        fi
    else
        # Strip leading 'v' if present
        requested_version="${requested_version#v}"
        url="https://github.com/Guepard-Corp/gfs/releases/download/v${requested_version}/$filename"
        specific_version=$requested_version

        # Verify the release exists before downloading
        http_status=$(curl -sI -o /dev/null -w "%{http_code}" "https://github.com/Guepard-Corp/gfs/releases/tag/v${requested_version}")
        if [ "$http_status" = "404" ]; then
            echo -e "${RED}Error: Release v${requested_version} not found${NC}"
            echo -e "${MUTED}Available releases: https://github.com/Guepard-Corp/gfs/releases${NC}"
            exit 1
        fi
    fi
fi

print_message() {
    local level=$1
    local message=$2
    local color=""

    case $level in
        info) color="${NC}" ;;
        warning) color="${NC}" ;;
        error) color="${RED}" ;;
    esac

    echo -e "${color}${message}${NC}"
}

check_version() {
    if command -v gfs >/dev/null 2>&1; then
        gfs_path=$(which gfs)

        ## Check the installed version
        installed_version=$(gfs --version 2>/dev/null | head -1 || echo "")
        # Extract just the version number if output is "gfs X.Y.Z" format
        installed_version=$(echo "$installed_version" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "$installed_version")

        if [[ "$installed_version" == "$specific_version" ]]; then
            print_message info "${MUTED}Version ${NC}$specific_version${MUTED} already installed"
            exit 0
        else
            print_message info "${MUTED}Installed version: ${NC}$installed_version${MUTED}. Upgrading to ${NC}$specific_version"
        fi
    fi
}

unbuffered_sed() {
    if echo | sed -u -e "" >/dev/null 2>&1; then
        sed -nu "$@"
    elif echo | sed -l -e "" >/dev/null 2>&1; then
        sed -nl "$@"
    else
        local pad="$(printf "\n%512s" "")"
        sed -ne "s/$/\\${pad}/" "$@"
    fi
}

print_progress() {
    local bytes="$1"
    local length="$2"
    [ "$length" -gt 0 ] || return 0

    local width=50
    local percent=$(( bytes * 100 / length ))
    [ "$percent" -gt 100 ] && percent=100
    local on=$(( percent * width / 100 ))
    local off=$(( width - on ))

    local filled=$(printf "%*s" "$on" "")
    filled=${filled// /■}
    local empty=$(printf "%*s" "$off" "")
    empty=${empty// /･}

    printf "\r${ORANGE}%s%s %3d%%${NC}" "$filled" "$empty" "$percent" >&4
}

download_with_progress() {
    local url="$1"
    local output="$2"

    if [ -t 2 ]; then
        exec 4>&2
    else
        exec 4>/dev/null
    fi

    local tmp_dir=${TMPDIR:-/tmp}
    local basename="${tmp_dir}/gfs_install_$$"
    local tracefile="${basename}.trace"

    rm -f "$tracefile"
    mkfifo "$tracefile"

    # Hide cursor
    printf "\033[?25l" >&4

    trap "trap - RETURN; rm -f \"$tracefile\"; printf '\033[?25h' >&4; exec 4>&-" RETURN

    (
        curl --trace-ascii "$tracefile" -s -L --connect-timeout 30 --max-time 600 -o "$output" "$url"
    ) &
    local curl_pid=$!

    unbuffered_sed \
        -e 'y/ACDEGHLNORTV/acdeghlnortv/' \
        -e '/^0000: content-length:/p' \
        -e '/^<= recv data/p' \
        "$tracefile" | \
    {
        local length=0
        local bytes=0

        while IFS=" " read -r -a line; do
            [ "${#line[@]}" -lt 2 ] && continue
            local tag="${line[0]} ${line[1]}"

            if [ "$tag" = "0000: content-length:" ]; then
                length="${line[2]}"
                length=$(echo "$length" | tr -d '\r')
                bytes=0
            elif [ "$tag" = "<= recv" ]; then
                local size="${line[3]}"
                bytes=$(( bytes + size ))
                if [ "$length" -gt 0 ]; then
                    print_progress "$bytes" "$length"
                fi
            fi
        done
    }

    wait $curl_pid
    local ret=$?
    echo "" >&4
    return $ret
}

download_and_install() {
    print_message info "\n${MUTED}Installing ${NC}gfs ${MUTED}version: ${NC}$specific_version"
    local tmp_dir="${TMPDIR:-/tmp}/gfs_install_$$"
    mkdir -p "$tmp_dir"

    if [[ "$os" == "windows" ]] || ! [ -t 2 ] || ! download_with_progress "$url" "$tmp_dir/$filename"; then
        # Fallback to standard curl on Windows, non-TTY environments, or if custom progress fails
        curl -# -L --connect-timeout 30 --max-time 600 -o "$tmp_dir/$filename" "$url"
    fi

    # Verify the download is valid (not a 404 HTML page)
    if ! gzip -t "$tmp_dir/$filename" 2>/dev/null; then
        echo -e "${RED}Error: Download failed or returned invalid content.${NC}"
        echo -e "${MUTED}The release may not have a binary for your platform ($combo).${NC}"
        echo -e "${MUTED}Check: https://github.com/Guepard-Corp/gfs/releases${NC}"
        echo -e "${MUTED}Or build from source: cargo build --release && ./install --binary target/release/gfs${NC}"
        rm -rf "$tmp_dir"
        exit 1
    fi

    # Extract the tar.gz archive (all platforms now use tar.gz)
    tar -xzf "$tmp_dir/$filename" -C "$tmp_dir"

    if [[ "$os" == "windows" ]]; then
        mv "$tmp_dir/gfs.exe" "$INSTALL_DIR/gfs.exe"
        chmod 755 "${INSTALL_DIR}/gfs.exe" 2>/dev/null || true
    else
        mv "$tmp_dir/gfs" "$INSTALL_DIR"
        chmod 755 "${INSTALL_DIR}/gfs"
    fi
    rm -rf "$tmp_dir"
}

install_from_binary() {
    print_message info "\n${MUTED}Installing ${NC}gfs ${MUTED}from: ${NC}$binary_path"
    cp "$binary_path" "${INSTALL_DIR}/gfs"
    chmod 755 "${INSTALL_DIR}/gfs"
}

if [ -n "$binary_path" ]; then
    install_from_binary
else
    check_version
    download_and_install
fi


add_to_path() {
    local config_file=$1
    local command=$2

    if grep -Fxq "$command" "$config_file"; then
        print_message info "Command already exists in $config_file, skipping write."
    elif [[ -w $config_file ]]; then
        echo -e "\n# gfs" >> "$config_file"
        echo "$command" >> "$config_file"
        print_message info "${MUTED}Successfully added ${NC}gfs ${MUTED}to \$PATH in ${NC}$config_file"
    else
        print_message warning "Manually add the directory to $config_file (or similar):"
        print_message info "  $command"
    fi
}

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}

current_shell=$(basename "$SHELL")
case $current_shell in
    fish)
        config_files="$HOME/.config/fish/config.fish"
    ;;
    zsh)
        config_files="${ZDOTDIR:-$HOME}/.zshrc ${ZDOTDIR:-$HOME}/.zshenv $XDG_CONFIG_HOME/zsh/.zshrc $XDG_CONFIG_HOME/zsh/.zshenv"
    ;;
    bash)
        config_files="$HOME/.bashrc $HOME/.bash_profile $HOME/.profile $XDG_CONFIG_HOME/bash/.bashrc $XDG_CONFIG_HOME/bash/.bash_profile"
    ;;
    ash)
        config_files="$HOME/.ashrc $HOME/.profile /etc/profile"
    ;;
    sh)
        config_files="$HOME/.ashrc $HOME/.profile /etc/profile"
    ;;
    *)
        # Default case if none of the above matches
        config_files="$HOME/.bashrc $HOME/.bash_profile $XDG_CONFIG_HOME/bash/.bashrc $XDG_CONFIG_HOME/bash/.bash_profile"
    ;;
esac

if [[ "$no_modify_path" != "true" ]]; then
    config_file=""
    for file in $config_files; do
        if [[ -f $file ]]; then
            config_file=$file
            break
        fi
    done

    if [[ -z $config_file ]]; then
        print_message warning "No config file found for $current_shell. You may need to manually add to PATH:"
        print_message info "  export PATH=$INSTALL_DIR:\$PATH"
    elif [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
        case $current_shell in
            fish)
                add_to_path "$config_file" "fish_add_path $INSTALL_DIR"
            ;;
            zsh)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            bash)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            ash)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            sh)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            *)
                export PATH=$INSTALL_DIR:$PATH
                print_message warning "Manually add the directory to $config_file (or similar):"
                print_message info "  export PATH=$INSTALL_DIR:\$PATH"
            ;;
        esac
    fi
fi

if [ -n "${GITHUB_ACTIONS-}" ] && [ "${GITHUB_ACTIONS}" == "true" ]; then
    echo "$INSTALL_DIR" >> $GITHUB_PATH
    print_message info "Added $INSTALL_DIR to \$GITHUB_PATH"
fi

# Inject AI tools (skills, agents, MCP) for detected tools - only when installing from release
inject_ai_tools() {
    if [[ "$skip_ai_tools" == "true" ]]; then
        return 0
    fi
    if [[ "${specific_version:-}" == "local" ]]; then
        return 0
    fi
    local detected
    detected=($(detect_ai_coding_tools))
    if [[ ${#detected[@]} -eq 0 ]]; then
        return 0
    fi

    local ai_tools_url="https://github.com/Guepard-Corp/gfs/releases/download/v${specific_version}/gfs-ai-tools-${specific_version}.tar.gz"
    local tmp_dir="${TMPDIR:-/tmp}/gfs_ai_tools_$$"
    mkdir -p "$tmp_dir"

    if ! curl -fsSL -o "$tmp_dir/gfs-ai-tools.tar.gz" "$ai_tools_url" 2>/dev/null; then
        echo -e "${MUTED}AI tools asset not found for v${specific_version}. Skipping injection.${NC}"
        rm -rf "$tmp_dir"
        return 0
    fi

    if ! tar -xzf "$tmp_dir/gfs-ai-tools.tar.gz" -C "$tmp_dir" 2>/dev/null; then
        echo -e "${MUTED}Failed to extract AI tools. Skipping injection.${NC}"
        rm -rf "$tmp_dir"
        return 0
    fi

    local release_url="https://github.com/Guepard-Corp/gfs/releases/tag/v${specific_version}"
    local injected=()
    local mcp_configured=()

    # GFS MCP config JSON fragment
    local gfs_mcp_json="\"gfs\": {\"command\": \"$INSTALL_DIR/gfs\", \"args\": [\"mcp\"]}"
    local gfs_mcp_opencode_json="\"gfs\": {\"command\": \"$INSTALL_DIR/gfs\", \"args\": [\"mcp\"], \"enabled\": true}"

    for tool in "${detected[@]}"; do
        case "$tool" in
            Cursor)
                mkdir -p "$HOME/.cursor/skills/use-gfs-cli" "$HOME/.cursor/skills/use-gfs-mcp" "$HOME/.cursor/agents"
                [[ -f "$tmp_dir/skills/use-gfs-cli/SKILL.md" ]] && cp "$tmp_dir/skills/use-gfs-cli/SKILL.md" "$HOME/.cursor/skills/use-gfs-cli/" && injected+=("$HOME/.cursor/skills/use-gfs-cli/SKILL.md")
                [[ -f "$tmp_dir/skills/use-gfs-mcp/SKILL.md" ]] && cp "$tmp_dir/skills/use-gfs-mcp/SKILL.md" "$HOME/.cursor/skills/use-gfs-mcp/" && injected+=("$HOME/.cursor/skills/use-gfs-mcp/SKILL.md")
                [[ -f "$tmp_dir/agents/qwery-agent.md" ]] && cp "$tmp_dir/agents/qwery-agent.md" "$HOME/.cursor/agents/" && injected+=("$HOME/.cursor/agents/qwery-agent.md")
                if command -v jq >/dev/null 2>&1; then
                    local mcp_file="$HOME/.cursor/mcp.json"
                    if [[ ! -f "$mcp_file" ]]; then
                        echo "{\"mcpServers\": {$gfs_mcp_json}}" | jq . > "$mcp_file" 2>/dev/null || echo "{\"mcpServers\": {$gfs_mcp_json}}" > "$mcp_file"
                    else
                        jq --arg cmd "$INSTALL_DIR/gfs" '.mcpServers.gfs = {"command": $cmd, "args": ["mcp"]}' "$mcp_file" > "$mcp_file.tmp" 2>/dev/null && mv "$mcp_file.tmp" "$mcp_file"
                    fi
                    mcp_configured+=("Cursor")
                else
                    [[ ! -f "$HOME/.cursor/mcp.json" ]] && echo "{\"mcpServers\": {$gfs_mcp_json}}" > "$HOME/.cursor/mcp.json" && mcp_configured+=("Cursor")
                fi
                ;;
            Claude)
                mkdir -p "$HOME/.claude/skills/use-gfs-cli" "$HOME/.claude/skills/use-gfs-mcp"
                [[ -f "$tmp_dir/skills/use-gfs-cli/SKILL.md" ]] && cp "$tmp_dir/skills/use-gfs-cli/SKILL.md" "$HOME/.claude/skills/use-gfs-cli/" && injected+=("$HOME/.claude/skills/use-gfs-cli/SKILL.md")
                [[ -f "$tmp_dir/skills/use-gfs-mcp/SKILL.md" ]] && cp "$tmp_dir/skills/use-gfs-mcp/SKILL.md" "$HOME/.claude/skills/use-gfs-mcp/" && injected+=("$HOME/.claude/skills/use-gfs-mcp/SKILL.md")
                local claude_config
                if [[ "$(uname -s)" == "Darwin"* ]]; then
                    claude_config="$HOME/Library/Application Support/Claude/claude_desktop_config.json"
                elif [[ -n "${APPDATA:-}" ]]; then
                    claude_config="$APPDATA/Claude/claude_desktop_config.json"
                else
                    claude_config="${XDG_CONFIG_HOME:-$HOME/.config}/Claude/claude_desktop_config.json"
                fi
                mkdir -p "$(dirname "$claude_config")"
                if command -v jq >/dev/null 2>&1; then
                    if [[ ! -f "$claude_config" ]]; then
                        echo "{\"mcpServers\": {$gfs_mcp_json}}" | jq . > "$claude_config" 2>/dev/null || echo "{\"mcpServers\": {$gfs_mcp_json}}" > "$claude_config"
                    else
                        jq --arg cmd "$INSTALL_DIR/gfs" '.mcpServers.gfs = {"command": $cmd, "args": ["mcp"]}' "$claude_config" > "$claude_config.tmp" 2>/dev/null && mv "$claude_config.tmp" "$claude_config"
                    fi
                    mcp_configured+=("Claude")
                else
                    [[ ! -f "$claude_config" ]] && echo "{\"mcpServers\": {$gfs_mcp_json}}" > "$claude_config" && mcp_configured+=("Claude")
                fi
                ;;
            OpenCode)
                mkdir -p "${XDG_CONFIG_HOME:-$HOME/.config}/opencode/skills/use-gfs-cli" "${XDG_CONFIG_HOME:-$HOME/.config}/opencode/skills/use-gfs-mcp" "${XDG_CONFIG_HOME:-$HOME/.config}/opencode/agents"
                local opencode_base="${XDG_CONFIG_HOME:-$HOME/.config}/opencode"
                [[ -f "$tmp_dir/skills/use-gfs-cli/SKILL.md" ]] && cp "$tmp_dir/skills/use-gfs-cli/SKILL.md" "$opencode_base/skills/use-gfs-cli/" && injected+=("$opencode_base/skills/use-gfs-cli/SKILL.md")
                [[ -f "$tmp_dir/skills/use-gfs-mcp/SKILL.md" ]] && cp "$tmp_dir/skills/use-gfs-mcp/SKILL.md" "$opencode_base/skills/use-gfs-mcp/" && injected+=("$opencode_base/skills/use-gfs-mcp/SKILL.md")
                [[ -f "$tmp_dir/agents/qwery-agent.md" ]] && cp "$tmp_dir/agents/qwery-agent.md" "$opencode_base/agents/" && injected+=("$opencode_base/agents/qwery-agent.md")
                local opencode_config="$opencode_base/opencode.json"
                if command -v jq >/dev/null 2>&1; then
                    if [[ ! -f "$opencode_config" ]]; then
                        echo "{\"mcp\": {$gfs_mcp_opencode_json}}" | jq . > "$opencode_config" 2>/dev/null || echo "{\"mcp\": {$gfs_mcp_opencode_json}}" > "$opencode_config"
                    else
                        jq --arg cmd "$INSTALL_DIR/gfs" '.mcp.gfs = {"command": $cmd, "args": ["mcp"], "enabled": true}' "$opencode_config" > "$opencode_config.tmp" 2>/dev/null && mv "$opencode_config.tmp" "$opencode_config"
                    fi
                    mcp_configured+=("OpenCode")
                else
                    [[ ! -f "$opencode_config" ]] && echo "{\"mcp\": {$gfs_mcp_opencode_json}}" > "$opencode_config" && mcp_configured+=("OpenCode")
                fi
                ;;
        esac
    done

    rm -rf "$tmp_dir"

    if [[ ${#injected[@]} -gt 0 ]]; then
        echo -e ""
        echo -e "${MUTED}GFS AI tools integration:${NC}"
        echo -e "  Injected (from $release_url):"
        for f in "${injected[@]}"; do
            echo -e "    $f"
        done
        if [[ ${#mcp_configured[@]} -gt 0 ]]; then
            echo -e "  MCP server configured for: ${mcp_configured[*]}"
        fi
        echo -e ""
    fi
}

inject_ai_tools

echo -e ""                                                                            
echo -e "${MUTED}▄▖▘▗   ▄▖       ▌  ▗   ▌         ▄▖    ▗        "
echo -e "${MUTED}▌ ▌▜▘  ▙▖▛▌▛▘  ▛▌▀▌▜▘▀▌▛▌▀▌▛▘█▌  ▚ ▌▌▛▘▜▘█▌▛▛▌▛▘"
echo -e "${MUTED}▙▌▌▐▖  ▌ ▙▌▌   ▙▌█▌▐▖█▌▙▌█▌▄▌▙▖  ▄▌▙▌▄▌▐▖▙▖▌▌▌▄▌"
echo -e "${MUTED}                                   ▄▌           "
echo -e ""
echo -e ""
echo -e "${MUTED}GFS uses Docker or Podman:${NC}"
echo -e ""
echo -e "cd <project>  ${MUTED}# Open directory${NC}"
echo -e "gfs      ${MUTED}# Run command${NC}"
